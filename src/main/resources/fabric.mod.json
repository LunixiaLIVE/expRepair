{
  "schemaVersion": 1,
  "id": "exprepair",
  "version": "${version}",
  "name": "expRepair",
  "description": "Repair your items using stored XP. Supports passive auto-repair and manual repair with configurable thresholds and cooldowns.",
  "authors": ["LunixiaLIVE"],
  "contact": {
    "sources": "https://github.com/LunixiaLIVE/expRepair"
  },
  "license": "MIT",
  "icon": "assets/exprepair/icon.png",
  "environment": "*",
  "entrypoints": {
    "fabric-datagen": [
      "net.lunix.exprepair.client.ExprepairDataGenerator"
    ],
    "main": [
      "net.lunix.exprepair.Exprepair"
    ]
  },
  "mixins": [
    "exprepair.mixins.json",
    {
      "config": "exprepair.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
